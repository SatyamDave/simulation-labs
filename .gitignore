# --- secrets ---
.env
*.pem

# --- python ---
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# --- node / frontend (web/, Agent 4) ---
node_modules/
web/dist/
web/.vite/
*.local

# --- runtime artifacts (video receipts, audio, generated reports) ---
artifacts/
*.webm
*.wav
!fixtures/**/*.wav

# --- os / editor ---
.DS_Store
.idea/
.vscode/

# TS build cache
*.tsbuildinfo
.run/

# --- hosted product (Phase 2+) ---
ghostpanel.db
*.db
*.db-journal
.sim/

# Local run output & artifacts (never commit).
# Every `sim` run writes to a .sim-<name>/ dir (.sim-try, .sim-demo, .sim-live,
# .sim-seg, .sim-deliverable*, …) and may leave a .sim-<name>.log — ignore the
# whole family so generated receipts never get committed again.
.sim-*/
.sim-*.log
.coverage

# Internal-only docs kept out of the public repo (strategy, build scaffolding)
.internal/
