# ---------------------------------------------------------------------------
# Ghostpanel environment. Copy to `.env` and fill in. NEVER commit `.env`.
# ---------------------------------------------------------------------------

# --- H Company Holo Models API (Agent 1) ---
# Get a key at https://hcompany.ai/holo-models-api  (format: hk-...)
HAI_API_KEY=hk-xxxxxxxxxxxxxxxxxxxxxxxx
HAI_BASE_URL=https://api.hcompany.ai/v1/
HAI_MODEL=holo3-1-35b-a3b
# Shared client-side rate limit — the whole swarm shares this. Free tier is
# 5 RPM, enforced server-side with even pacing and NO burst allowance (verified:
# bursts get 429 + retry-after=11s), so don't set this above your real tier.
HAI_RPM=5
# Widest frame sent to Holo (px). Frames wider than this are downscaled for
# transport (coords are rescaled back) — smaller = faster inference per step.
HAI_IMG_MAX_W=1024

# --- Gradium voice (Agent 5) ---
# Create a key at https://accounts.gradium.ai/sign-in (format: gd-...), then
# redeem the hackathon code LETSHACKGRADIUM202607 at
# https://studio.gradium.ai/platform/subscription
GRADIUM_API_KEY=gd-xxxxxxxxxxxxxxxxxxxxxxxx

# --- Anthropic (Agent 5: turns an action trace into a first-person exit interview) ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-sonnet-5

# --- Server (Agent 3) ---
GHOSTPANEL_HOST=127.0.0.1
GHOSTPANEL_PORT=8000
# Where video receipts / audio / reports are written.
GHOSTPANEL_ARTIFACT_DIR=./artifacts

# --- NemoClaw / NVIDIA challenge (optional stretch, Agent 3) ---
# When set, Holo inference is routed through the OpenShell policy gateway.
# Leave blank to call Holo directly.
NEMOCLAW_GATEWAY_URL=
